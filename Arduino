#include <Arduino.h>

int multiply(int a, int b) {
    return a * b;
}

void setup() {
    Serial.begin(9600);
    while (!Serial) { ; } 

    int myNumber = 7; 

    Serial.println("--- Multiplication Table ---");
    for (int i = 0; i <= 9; i++) {
        int result = multiply(myNumber, i);
        
        Serial.print(myNumber);
        Serial.print(" * ");
        Serial.print(i);
        Serial.print(" = ");
        Serial.println(result);
    }
}

void loop() {
    
}
